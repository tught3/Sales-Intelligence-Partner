# ====================================================================
# JW 영업 비서 - 환경변수 템플릿
# ====================================================================
# 이 파일은 GitHub에 안전하게 올라갑니다 (값이 비어있으니까).
# 실제 값을 채운 .env 파일은 절대 GitHub에 커밋하지 마세요.
#
# 사용법:
#   1. 이 파일을 .env 로 복사: cp .env.example .env
#   2. 아래 값들을 본인 환경에 맞게 채워넣기
#   3. 서버 실행: pnpm install && pnpm --filter @workspace/sales-intelligence run dev
# ====================================================================


# --- 데이터베이스 (PostgreSQL) ---
# Neon, Supabase, 또는 직접 호스팅한 Postgres 접속 주소
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# 개별 접속 정보 (선택사항 - DATABASE_URL이 있으면 보통 불필요)
PGHOST=
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=


# --- Anthropic Claude API (AI 일지 생성용) ---
# https://console.anthropic.com 에서 API 키 발급
# Replit AI 통합을 사용 중이신데, 외부 환경에선 본인 키를 직접 받아야 합니다.
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com


# --- (선택) OpenAI - 현재는 사용 안 함 ---
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=


# --- 세션 시크릿 (랜덤 문자열) ---
# 직접 만드시려면: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string


# --- 서버 포트 (선택) ---
# Replit에선 자동 할당됩니다. 본인 서버에선 원하는 포트 지정.
PORT=5000
API_SERVER_PORT=3001
NODE_ENV=development
